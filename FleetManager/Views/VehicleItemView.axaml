<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:FleetManager.Models"
             xmlns:vm="clr-namespace:FleetManager.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FleetManager.Views.VehicleItemView"
             x:DataType="models:Vehicle">
    
    <Border CornerRadius="12"
            Background="#1E1E1E"
            Padding="16"
            Margin="10"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            Width="450">
        <StackPanel Spacing="6">
            
            <!-- Nazwa pojazdu -->
            <TextBlock Text="{Binding Name}"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#F5F5F5"/>

            <!-- Numer rejestracyjny -->
            <TextBlock Text="{Binding RegistrationNumber}"
                       FontSize="16"
                       Foreground="#CFCFCF"/>

            <!-- Poziom paliwa -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Paliwo:"
                           Foreground="#8A8A8A"/>
                <TextBlock Text="{Binding Fuel}"
                           Foreground="#E0E0E0"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Status pojazdu -->
            <Border CornerRadius="6"
                    Padding="4,2"
                    HorizontalAlignment="Left"
                    Background="{Binding Status}"> <!-- Converter={StaticResource StatusToColorConverter} -->
                <TextBlock Text="{Binding Status}"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="14"/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>

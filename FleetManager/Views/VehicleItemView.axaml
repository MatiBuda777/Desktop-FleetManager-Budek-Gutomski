<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FleetManager.ViewModels"
             x:Class="FleetManager.Views.VehicleItemView"
             x:DataType="vm:VehicleItemViewModel"
             Margin="10">

    <Border Background="#2D2D30" CornerRadius="8" Padding="15" BoxShadow="0 4 8 0 #40000000">
        <StackPanel Spacing="10" Width="250">
      
            <TextBlock Text="{Binding Vehicle.Name}" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="{Binding Vehicle.RegistrationNumber}" FontSize="14" Foreground="LightGray"/>

            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Status:" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="{Binding Vehicle.Status}" Foreground="#4DA8DA"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="{Binding Vehicle.Fuel, StringFormat='Paliwo: {0}%'}" Foreground="White"/>
                <ProgressBar Value="{Binding Vehicle.Fuel}" Minimum="0" Maximum="100" Height="10" Foreground="#4CAF50" Background="#555555"/>
            </StackPanel>

            <UniformGrid Columns="2" Rows="2" Margin="0,10,0,0">
                <Button Content="Tankuj" Command="{Binding RefuelCommand}" Margin="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="W Trasę" Command="{Binding DispatchCommand}" Margin="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Serwis" Command="{Binding ServiceCommand}" Margin="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Dostępny" Command="{Binding MakeAvailableCommand}" Margin="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            </UniformGrid>
      
        </StackPanel>
    </Border>
</UserControl>